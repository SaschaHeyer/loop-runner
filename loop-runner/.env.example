# Cloud Run Job env (set on the Job via deploy.sh --set-env-vars / --set-secrets).
# This file documents what the Job expects; you do NOT source it locally for a real run.
# The harness image is loop-agnostic — LOOP picks the spec; the spec drives model/turns/prompt.

# --- which loop + which agent CLI ---
export LOOP="ceo"                         # matches loops/<name>/loop.yaml (ceo | error-sweep | ...)
export AGENT_CLI="claude"                 # claude (default, proven) | agy (antigravity CLI)

# model / max_turns / prompt / verifier / skills / identity all come from loops/$LOOP/loop.yaml
# at runtime — NOT from env — so editing the spec takes effect on the next run with no redeploy.
# (You can still force an override for a one-off run, e.g. MODEL=claude-sonnet-4-6.)

# --- repo (git-as-memory; cloned fresh each loop) ---
export REPO_FULL_NAME="SaschaHeyer/loop-runner"

# --- project / identity ---
export GCP_PROJECT="your-gcp-project"
export SECRET_MANAGER_PROJECT="your-gcp-project"
export DEPLOY_SA="loop-runner@your-gcp-project.iam.gserviceaccount.com"

# --- Claude Code on Vertex (no API key; auth is the Job's service account) ---
export CLAUDE_CODE_USE_VERTEX="1"
export ANTHROPIC_VERTEX_PROJECT_ID="your-gcp-project"
export CLOUD_ML_REGION="global"           # Claude 4.6/4.8 serve from the global endpoint

# --- harness knobs ---
export COST_LOG="cost_log.yaml"    # appended in the same schema as the managed runner
export SESSIONS_BUCKET="your-gcp-project-loop-sessions"         # per-run transcript archive (namespaced by loop)
export SMOKE="0"                          # 1 = constrained harness validation (no loop actions)
# export PROXY_SELFTEST_URL="..."         # override the proxy keystone check for a non-GCP loop
# export PUSH_OVERRIDE="none"             # dry run: forces the 'none' push path + PERSIST_PUSH=0
#                                          # regardless of the loop's own push: setting. Commits
#                                          # still happen locally; nothing reaches origin. Prints a
#                                          # "DRY RUN" line + the would-be diffstat instead.

# --- secrets (injected from Secret Manager via --set-secrets; the LOCAL egress proxy uses them) ---
# GITHUB_PAT          <- secret github-pat
# RESEND_API_KEY      <- secret resend-api-key
# STRIPE_SECRET_KEY   <- secret stripe-secret-key
# CLOUDFLARE_API_TOKEN<- secret cloudflare-api-token
